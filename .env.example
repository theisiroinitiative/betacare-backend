# Server Configuration
PORT=5000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/betacare

# Redis Configuration (for OTP and session cache)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Secrets (Authentication)
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Email Service (Resend API)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# WhatsApp Integration
BOT_PHONE_NUMBER=your_bot_phone_number_here
WHATSAPP_BOT_NUMBER=BetaCare Bot

# Google Gemini API Configuration (for AI Medical History Companion)
GEMINI_API_KEY=your_gemini_api_key_here
